# Data — ignored by default. A few small version-controlled artefacts
# under data/ are the exception: audit/discovery CSVs in data/reports/,
# and the Wayback-derived USCG bulletin ID index in data/raw/uscg_bulletins/
# (source of truth for the GovDelivery bulletin ingest sprint — small text
# file, reproducible, needs to survive across machines).
# Git requires un-ignoring each parent directory in order before a leaf
# path can be included. Order matters: ignore broad, then carve holes.
data/*
!data/reports/
!data/raw/
data/raw/*
!data/raw/uscg_bulletins/
data/raw/uscg_bulletins/*
!data/raw/uscg_bulletins/wayback_ids.txt
!data/raw/uscg_bulletins/regression_set.json
packages/ingest/data/

# PWA
public/sw.js
public/workbox-*.js
public/swe-worker-*.js
apps/web/public/sw.js
apps/web/public/workbox-*.js
apps/web/public/fallback-*.js
apps/web/public/swe-worker-*.js

# Build
*.tsbuildinfo
".env.txt" 
".env.txt" 
.claude/scheduled_tasks.lock
