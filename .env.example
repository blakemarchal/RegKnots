# =============================================================================
# RegKnots — environment variables
# Copy this file to .env and fill in your values.
# .env lives at the REPO ROOT and is loaded by all packages automatically.
# =============================================================================

# ── Docker Compose (PostgreSQL) ───────────────────────────────────────────────
POSTGRES_USER=regknots
POSTGRES_PASSWORD=regknots_dev
POSTGRES_DB=regknots

# ── FastAPI (REGKNOTS_ prefix, loaded by pydantic-settings) ──────────────────
REGKNOTS_DATABASE_URL=postgresql://regknots:regknots_dev@localhost:5432/regknots
REGKNOTS_REDIS_URL=redis://localhost:6379/0
REGKNOTS_CORS_ORIGINS=["http://localhost:3000"]
REGKNOTS_ENVIRONMENT=development

# JWT secret — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
REGKNOTS_JWT_SECRET_KEY=CHANGE_ME_generate_a_real_secret_for_production

# Token lifetimes (these are the defaults — uncomment to override)
# REGKNOTS_ACCESS_TOKEN_EXPIRE_MINUTES=15
# REGKNOTS_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AI API Keys (shared by ingest pipeline and RAG engine) ───────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Sentry (monitoring) ──────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=

# ── Resend (transactional email) ──────────────────────────────────────────────
RESEND_API_KEY=

# ── Stripe (billing) ──────────────────────────────────────────────────────────
# Legacy pre-D6.1 single-tier prices. Kept for backward compat with any
# historical webhooks; safe to unset once D6.1 two-tier pricing is verified.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=
STRIPE_ANNUAL_PRICE_ID=

# Sprint D6.1 — two-tier pricing. Create six prices in Stripe under two
# products (RegKnots Mate, RegKnots Captain) and paste each price_id here.
# See docs/stripe-setup.md (or the Sprint D6.1 PR body) for exact product
# and price configuration.
#
# Mate — 100 messages per month cap
STRIPE_PRICE_MATE_MONTHLY=price_...      # $19.99/month
STRIPE_PRICE_MATE_ANNUAL=price_...       # $179.88/year, displayed as $14.99/mo
STRIPE_PRICE_MATE_PROMO=price_...        # $14.99/month (charity partner pricing)
#
# Captain — unlimited messages
STRIPE_PRICE_CAPTAIN_MONTHLY=price_...   # $39.99/month
STRIPE_PRICE_CAPTAIN_ANNUAL=price_...    # $359.88/year, displayed as $29.99/mo
STRIPE_PRICE_CAPTAIN_PROMO=price_...     # $29.99/month (charity partner pricing)

# ── Ingest pipeline ───────────────────────────────────────────────────────────
# Reads REGKNOTS_DATABASE_URL and OPENAI_API_KEY above — no additional vars needed.
