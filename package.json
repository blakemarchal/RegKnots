{
  "name": "regknots",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --filter @regknots/web dev",
    "dev:api": "cd apps/api && uv run uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "build:web": "pnpm --filter @regknots/web build",
    "lint:web": "pnpm --filter @regknots/web lint",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "ingest": "cd packages/ingest && uv run python -m ingest.cli"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
